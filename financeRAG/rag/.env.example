# FinanceRAG RAG 配置
# 复制为 financeRAG/rag/.env 后填入真实 key

# DashScope / 通义千问 OpenAI-compatible API key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# LLM_MODEL 只用于 query_chroma.py --answer 阶段
LLM_MODEL=qwen3.6-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# EMBEDDING_MODEL 用于 build_chroma_index.py 写入向量
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Chroma 本地持久化配置
CHROMA_PERSIST_DIR=financeRAG/rag/chroma_db
CHROMA_COLLECTION=finance_rag
